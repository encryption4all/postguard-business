# Database
DATABASE_URL="postgres://user:password@localhost:5432/postguard_business"

# Yivi (YIVI_SERVER_URL and YIVI_SERVER_TOKEN set in docker-compose / k8s)
YIVI_DEMO_ATTRIBUTES=true

# Seed: override admin credentials (optional, defaults to demo values)
# ADMIN_EMAIL=admin@postguard.eu
# ADMIN_FULL_NAME=Jan de Admin
# ADMIN_PHONE=0612345678

# Feature Flags (set to "true" to enable)
FF_PRICING_PAGE=false
FF_REGISTRATION=false
FF_PORTAL_API_KEYS=false
FF_PORTAL_ORG_INFO=false
FF_PORTAL_EMAIL_LOG=false
FF_PORTAL_DNS=false
FF_PORTAL_MEMBERS=false
FF_ADMIN_PANEL=false
FF_ADMIN_ORG_STATUS=false
FF_ADMIN_AUDIT_LOG=false
FF_ADMIN_IMPERSONATION=false
