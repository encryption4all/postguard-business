{
	"name": "postguard-business",
	"private": true,
	"version": "1.3.1",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync && husky || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"lint": "prettier --check . && eslint . --max-warnings 0",
		"format": "prettier --write .",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "tsx scripts/migrate.ts",
		"db:seed": "tsx scripts/seed.ts",
		"db:studio": "drizzle-kit studio",
		"db:check": "tsx scripts/check-migrations.ts"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/kit": "^2.69.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^26.1.0",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.6.0",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"husky": "^9.1.7",
		"postgres": "^3.4.9",
		"prettier": "^3.9.4",
		"prettier-plugin-svelte": "^4.1.1",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.1",
		"vite": "^8.1.2",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@iconify/svelte": "^5.2.2",
		"@privacybydesign/yivi-client": "^1.0.0",
		"@privacybydesign/yivi-core": "^1.0.0",
		"@privacybydesign/yivi-css": "^1.0.1",
		"@privacybydesign/yivi-web": "^1.0.2",
		"pino": "^10.3.1",
		"sass": "^1.101.0",
		"svelte-i18n": "^4.0.1",
		"zod": "^4.4.3"
	},
	"overrides": {
		"@sveltejs/kit": {
			"cookie": "^0.7.2"
		},
		"svelte-i18n": {
			"esbuild": "^0.25.0"
		},
		"@esbuild-kit/core-utils": {
			"esbuild": "^0.25.0"
		}
	}
}
