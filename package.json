{
	"name": "postguard-business",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "playwright install && svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "tsx scripts/migrate.ts",
		"db:seed": "tsx scripts/seed.ts",
		"db:studio": "drizzle-kit studio"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^24",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.2.0",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"postgres": "^3.4.9",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.3"
	},
	"dependencies": {
		"@iconify/svelte": "^5.2.1",
		"@privacybydesign/yivi-client": "^1.0.0-beta.4",
		"@privacybydesign/yivi-core": "^1.0.0-beta.4",
		"@privacybydesign/yivi-css": "^1.0.0-beta.4",
		"@privacybydesign/yivi-web": "^1.0.0-beta.4",
		"sass": "^1.99.0",
		"svelte-i18n": "^4.0.1"
	}
}
