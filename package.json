{
	"name": "postguard-business",
	"private": true,
	"version": "1.3.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync && husky || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"lint": "prettier --check . && eslint . --max-warnings 0",
		"format": "prettier --write .",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "tsx scripts/migrate.ts",
		"db:seed": "tsx scripts/seed.ts",
		"db:studio": "drizzle-kit studio",
		"db:check": "tsx scripts/check-migrations.ts"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.60.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^25.9.1",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.4.0",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"postgres": "^3.4.9",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.2",
		"svelte": "^5.55.8",
		"svelte-check": "^4.4.8",
		"tsx": "^4.22.3",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.4",
		"vite": "^8.0.13",
		"vitest": "^4.1.6"
	},
	"dependencies": {
		"@iconify/svelte": "^5.2.1",
		"@privacybydesign/yivi-client": "^1.0.0",
		"@privacybydesign/yivi-core": "^1.0.0",
		"@privacybydesign/yivi-css": "^1.0.1",
		"@privacybydesign/yivi-web": "^1.0.1",
		"sass": "^1.99.0",
		"svelte-i18n": "^4.0.1"
	},
	"overrides": {
		"@sveltejs/kit": {
			"cookie": "^0.7.2"
		},
		"svelte-i18n": {
			"esbuild": "^0.25.0"
		},
		"@esbuild-kit/core-utils": {
			"esbuild": "^0.25.0"
		}
	}
}
